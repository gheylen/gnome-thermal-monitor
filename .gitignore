# ── Build output ──────────────────────────────────────────────────────────────
dist/
schemas/gschemas.compiled

# ── Node.js (dev tooling only) ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store           # macOS

# ── Editors & IDEs ────────────────────────────────────────────────────────────
.vscode/            # VS Code
.idea/              # JetBrains (IntelliJ, WebStorm, CLion, …)
.fleet/             # JetBrains Fleet
.zed/               # Zed
*.sublime-project   # Sublime Text
*.sublime-workspace
*.kate-swp          # Kate
*.swp               # Vim / Neovim
*.swo
.*.swp
*~                  # Emacs / general editor backups
\#*\#               # Emacs auto-save
.#*                 # Emacs lock files
*.orig              # Merge conflict originals
*.bak

# ── AI assistant tooling ──────────────────────────────────────────────────────
.claude/            # Claude Code local settings (per-developer, not shared)
